#!/bin/bash
# ============================================================
# cc-switch — Claude Code 多模型启动器
# 用法: cc-switch <模型名> [claude 参数...]
# 例如: cc-switch deepseek --resume
#
# 配置目录: ~/.claude/providers/<模型名>.env
# ============================================================

set -euo pipefail

PROVIDER="${1:-}"

if [ -z "$PROVIDER" ]; then
    echo "⚠️  缺少模型名称"
    echo "用法: cc-switch <模型名称> [其他 claude 参数]"
    echo ""
    echo "可用模型:"
    for f in "$HOME/.claude/providers/"*.env; do
        [ -f "$f" ] && echo "  • $(basename "$f" .env)"
    done
    exit 1
fi

shift

CONF_FILE="$HOME/.claude/providers/${PROVIDER}.env"

if [ ! -f "$CONF_FILE" ]; then
    echo "❌ 未找到模型配置: $CONF_FILE"
    echo ""
    echo "可用模型:"
    for f in "$HOME/.claude/providers/"*.env; do
        [ -f "$f" ] && echo "  • $(basename "$f" .env)"
    done
    exit 1
fi

export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"
export CLAUDE_CODE_EFFORT_LEVEL="max"

source "$CONF_FILE"

echo "🚀 正在使用 [$PROVIDER] 引擎启动 Claude Code..."
exec claude "$@"
