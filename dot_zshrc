# chezmoi 跨平台一键无脑同步函数（完美兼容 Mac & Linux）
czsync() {
    # 1. 跨平台安全时间戳（避开 BSD/GNU date 差异）
    local current_time
    current_time=$(date "+%Y-%m-%d_%H:%M:%S")

    # 2. 先拉取远端更新（rebase + autostash 处理本地未提交改动）
    echo "🔄 [Chezmoi] 正在拉取远端更新 (rebase + autostash)..."
    if ! chezmoi git -- pull --rebase --autostash; then
        echo "❌ [Chezmoi] 拉取失败，请检查网络/SSH Key/冲突。"
        return 1
    fi

    # 3. 显式 add 跨平台基础配置文件（不依赖 chezmoi 智能识别）
    echo "🚀 [Chezmoi] 正在识别原位修改..."
    if [ -f "$HOME/.zshrc" ]; then chezmoi add "$HOME/.zshrc"; fi
    if [ -f "$HOME/.bashrc" ]; then chezmoi add "$HOME/.bashrc"; fi

    # 兜底：扫所有 chezmoi 已管理的文件, 重新 add 检测到的所有变更
    # 这样 ~/.ssh/config, ~/.gitconfig 等任何 managed 文件改了都会被自动捡到
    while IFS= read -r managed_file; do
        [ -n "$managed_file" ] || continue
        [ -f "$managed_file" ] || continue
        chezmoi add "$managed_file" 2>/dev/null || true
    done < <(chezmoi managed 2>/dev/null)

    # 4. 检查是否有变更需要提交
    if [ -n "$(chezmoi git -- status --porcelain)" ]; then
        echo "📝 [Chezmoi] 检测到配置变更，正在自动提交..."
        chezmoi git -- add .
        chezmoi git -- commit -m "auto sync: ${current_time}"

        echo "📤 [Chezmoi] 正在推送到远端 GitHub 仓库..."
        if chezmoi git -- push; then
            echo "✅ [Chezmoi] 跨平台同步成功！"
        else
            echo "❌ [Chezmoi] 推送失败，请检查网络或 SSH Key。"
        fi
    else
        echo "✨ [Chezmoi] 没有检测到任何文件修改，无需同步。"
    fi
}

