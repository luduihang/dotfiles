# chezmoi 跨平台一键无脑同步函数（完美兼容 Mac & Linux）
czsync() {
    # 1. 跨平台安全时间戳（避开 BSD/GNU date 差异）
    local current_time
    current_time=$(date "+%Y-%m-%d_%H:%M:%S")

    echo "🚀 [Chezmoi] 正在识别原位修改，自动 smart add..."
    # --smart 会自动识别被修改的受管文件，跳过未管理文件
    chezmoi add --smart
    
    # 2. 检查 chezmoi 内部是否有文件变更（暂存区或工作区）
    # 使用 git status --porcelain 是目前最快、最不依赖终端终端高亮的判断方式
    if [ -n "$(chezmoi git -- status --porcelain)" ]; then
        echo "📝 [Chezmoi] 检测到配置变更，正在自动提交..."
        
        # 顺畅执行 git 流水线，age 会在后台静默处理加密文件
        chezmoi git -- add .
        chezmoi git -- commit -m "auto sync: ${current_time}"
        
        echo "📤 [Chezmoi] 正在推送到远端 GitHub 仓库..."
        if chezmoi git -- push; then
            echo "✅ [Chezmoi] 跨平台同步成功！"
        else
            echo "❌ [Chezmoi] 推送失败，请检查网络或 SSH Key。"
        fi
    else
        echo "✨ [Chezmoi] 没有检测到任何文件修改，无需同步。"
    fi
}

# 绑定极客快捷别名
alias csz="czsync"

