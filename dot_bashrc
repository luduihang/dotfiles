# >>> conda initialize (auto-detect anaconda/miniconda, cross-platform) >>>
_conda_paths=(
    "$HOME/anaconda3"
    "$HOME/miniconda3"
    "/opt/anaconda3"
    "/opt/miniconda3"
    "/opt/homebrew/anaconda3"
)
for _conda_root in "${_conda_paths[@]}"; do
    if [ -x "$_conda_root/bin/conda" ]; then
        __conda_setup="$("$_conda_root/bin/conda" 'shell.bash' 'hook' 2>/dev/null)"
        if [ $? -eq 0 ]; then
            eval "$__conda_setup"
        elif [ -f "$_conda_root/etc/profile.d/conda.sh" ]; then
            . "$_conda_root/etc/profile.d/conda.sh"
        else
            export PATH="$_conda_root/bin:$PATH"
        fi
        unset __conda_setup _conda_root _conda_paths
        conda activate base
        break
    fi
done
unset _conda_root _conda_paths
