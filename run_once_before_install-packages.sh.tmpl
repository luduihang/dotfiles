#!/bin/bash
# ---------------------------------------------------------------------
# Chezmoi 自动化依赖安装脚本 (Mac & Linux 通用)
# 执行时机：在应用配置文件(Apply)之前自动运行
# ---------------------------------------------------------------------

echo "⚙️ 正在检查并安装极客环境基础依赖..."

# 1. 如果是 macOS 环境
{{ if eq .chezmoi.os "darwin" }}
    echo "🍏 检测到 macOS 系统，正在通过 Homebrew 检查依赖..."
    for pkg in age zoxide yazi fzf zellij; do
        if ! command -v $pkg &> /dev/null; then
            echo "📦 正在安装 $pkg..."
            brew install $pkg
        else
            echo "✅ $pkg 已安装"
        fi
    done

# 2. 如果是 Linux 环境 (无桌面服务器/容器)
{{ else if eq .chezmoi.os "linux" }}
    echo "🐧 检测到 Linux 系统，正在检查依赖..."
    
    # 更新系统包管理器
    sudo apt-get update -y && sudo apt-get install -y curl git fzf

    # 自动化安装 age (如果缺失)
    if ! command -v age &> /dev/null; then
        echo "🔒 正在安装 age 加密工具..."
        sudo apt-get install -y age || {
            # 如果 apt 找不到，利用官方二进制包直接捞
            curl -Lo /tmp/age.tar.gz "https://github.com/FiloSottile/age/releases/latest/download/age-linux-amd64.tar.gz"
            tar -f /tmp/age.tar.gz -C /tmp/
            sudo mv /tmp/age/age* /usr/local/bin/
        }
    fi

    # 自动化安装 zoxide (智能 cd)
    if ! command -v zoxide &> /dev/null; then
        echo "🚀 正在安装 zoxide..."
        curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
    fi

    # 自动化安装 Zellij
    if ! command -v zellij &> /dev/null; then
        echo "🪟 正在安装 Zellij..."
        cargo install zellij 2>/dev/null || {
            # 没装 cargo 的话直接抓最新 Release 二进制
            curl -L -o /tmp/zellij.tar.gz "https://github.com/zellij-org/zellij/releases/latest/download/zellij-x86_64-unknown-linux-musl.tar.gz"
            tar -xzvf /tmp/zellij.tar.gz -C /tmp/
            sudo mv /tmp/zellij /usr/local/bin/
        }
    fi
{{ end }}

echo "🎉 基础依赖检测与安装流程执行完毕！"
