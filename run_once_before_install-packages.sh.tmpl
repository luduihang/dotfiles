#!/bin/bash
# ---------------------------------------------------------------------
# Chezmoi 自动化依赖安装脚本 (Mac & Linux 通用)
# 执行时机：在应用配置文件(Apply)之前自动运行
# 离线安全: 联网操作失败不中断 apply
# ---------------------------------------------------------------------

set +e

echo "⚙️ 正在检查并安装基础依赖..."

# 检测是否有网络连接
online() { timeout 2 curl -s --head https://github.com > /dev/null 2>&1; }

{{ if eq .chezmoi.os "darwin" }}
    echo "🍏 macOS — 通过 Homebrew 检查依赖..."
    for pkg in age zoxide yazi fzf zellij; do
        if command -v $pkg &> /dev/null; then
            echo "✅ $pkg 已安装"
        elif online; then
            echo "📦 正在安装 $pkg..."
            brew install $pkg || echo "⚠️  $pkg 安装失败，跳过"
        else
            echo "⚠️  离线模式，跳过安装 $pkg"
        fi
    done

{{ else if eq .chezmoi.os "linux" }}
    echo "🐧 Linux — 检查依赖..."

    if online; then
        sudo apt-get update -y 2>/dev/null || true
        sudo apt-get install -y curl git fzf 2>/dev/null || true

        if ! command -v age &> /dev/null; then
            echo "🔒 安装 age..."
            sudo apt-get install -y age 2>/dev/null || {
                curl -Lo /tmp/age.tar.gz "https://github.com/FiloSottile/age/releases/latest/download/age-linux-amd64.tar.gz"
                tar -xf /tmp/age.tar.gz -C /tmp/
                sudo mv /tmp/age/age* /usr/local/bin/
            }
        fi

        if ! command -v zoxide &> /dev/null; then
            echo "🚀 安装 zoxide..."
            curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
        fi

        if ! command -v zellij &> /dev/null; then
            echo "🪟 安装 Zellij..."
            cargo install zellij 2>/dev/null || {
                curl -L -o /tmp/zellij.tar.gz "https://github.com/zellij-org/zellij/releases/latest/download/zellij-x86_64-unknown-linux-musl.tar.gz"
                tar -xzvf /tmp/zellij.tar.gz -C /tmp/
                sudo mv /tmp/zellij /usr/local/bin/
            }
        fi
    else
        echo "⚠️  离线模式 — 跳过 apt/curl 联网安装，仅检查已有依赖"
        for bin in age zoxide zellij fzf; do
            command -v $bin &> /dev/null && echo "✅ $bin" || echo "⚠️  $bin 缺失（离线环境请手动安装）"
        done
    fi
{{ end }}

echo "🎉 依赖检查完成！"
